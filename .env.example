# ============================================================
# Aletheia — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control.
# ============================================================

# --- Flask Backend ---
# Secret key for Flask session management (generate a random string)
FLASK_SECRET_KEY=your-secret-key-here

# --- Tavily Search API (Web Search for Plant Data) ---
# Primary keys. Multiple keys supported for rotation.
# Get keys at: https://tavily.com
TAVILY_API_KEY_1=your-tavily-key-1
TAVILY_API_KEY_BE=your-tavily-key-backup
TAVILY_API_KEY=your-tavily-key-fallback

# --- OpenRouter API (AI Reasoning / LLM) ---
# Used for AI-powered plant analysis explanations.
# Get key at: https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-key

# --- Optional: Additional LLM Providers ---
# Not required for production — OpenRouter is the primary provider.
# DEEPSEEK_API_KEY=your-deepseek-key
# GEMINI_API_KEY=your-gemini-key
# XAI_API_KEY=your-xai-key
# NARAROUTER_API_KEY=your-nararouter-key

# --- Frontend (Vercel / Static Hosting) ---
# Set this to your deployed backend URL.
# For Hugging Face Spaces: https://your-space-name.hf.space
# For local development: http://127.0.0.1:5000
NEXT_PUBLIC_API_URL=https://your-backend-url.com